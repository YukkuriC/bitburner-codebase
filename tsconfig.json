{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "/*": ["./*"]
        },
        "target": "es2020",
        "allowJs": true,
        "noEmit": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "lib": ["es2020", "DOM"],
        "downlevelIteration": true
    },
    "include": ["**/*.js", "**/*.ts", "**/*.d.ts"],
    "exclude": ["node_modules", "old"]
}
